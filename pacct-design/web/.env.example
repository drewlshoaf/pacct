# TrustedModel Web Environment Variables

# ============================================
# Environment
# ============================================
NODE_ENV=development

# ============================================
# API Endpoints
# ============================================

# Public API URL (exposed to browser, used for client-side requests)
# Local development: http://localhost:3000
# Production: https://api.trustedmodel.com
NEXT_PUBLIC_API_URL=http://localhost:3000

# Internal API URL (server-side only, for SSR)
# Local development: http://localhost:3000
# Docker development: http://api:3000
# Production: https://api.trustedmodel.com
API_URL=http://localhost:3000

# ============================================
# Database
# ============================================

# Postgres + TimescaleDB connection string
DATABASE_URL=postgres://loadtoad:loadtoad@localhost:5432/loadtoad

# ============================================
# Redis
# ============================================

REDIS_URL=redis://localhost:6379

# ============================================
# Injector Scaling
# ============================================
# These control how LoadToad distributes load across injector instances.
# Runtime-configurable values can also be set from the Infrastructure dashboard.
# See packages/executor/src/config.ts for full documentation.

# Max virtual users per injector process before spawning another (50–2000)
# LT_VUS_PER_INJECTOR=250

# Hard cap on injector count per run (1–50)
# LT_MAX_INJECTORS=10

# Parallel load segments each worker container runs (1–8)
# LT_SEGMENT_CONCURRENCY=2

# BullMQ stall timeout for long-running coordinator jobs (ms)
# LT_WORKER_LOCK_DURATION_MS=660000

# ============================================
# Worker Infrastructure (Docker Compose only)
# ============================================
# These only apply when running via docker compose.

# Number of worker containers
# LT_WORKER_REPLICAS=3

# CPU cores per worker container
# LT_WORKER_CPU_LIMIT=2.0

# Memory per worker container
# LT_WORKER_MEM_LIMIT=2G

# ============================================
# AI Provider
# ============================================

# Anthropic API key for AI narrative generation
# ANTHROPIC_API_KEY=

# Note: NEXT_PUBLIC_* variables are baked into the browser bundle at build time
# All other variables are server-side only and not exposed to the client
